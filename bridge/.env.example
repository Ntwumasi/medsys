# MedSys cloud API base URL (no trailing slash)
MEDSYS_API_URL=https://medsys.vercel.app

# Shared secret with the MedSys server (set on both sides). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
BRIDGE_API_KEY=

# Where Orthanc reads worklist files from (orthanc-worklists plugin "Database")
WORKLIST_DIR=C:\OrthancWorklists

# Path to DCMTK's dump2dcm.exe — used to convert .dump text files into binary .wl
DUMP2DCM_PATH=C:\Program Files\DCMTK\bin\dump2dcm.exe

# Orthanc REST API (kept localhost-only — bridge runs on the same box)
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=medsys
ORTHANC_PASSWORD=

# How often the bridge polls MedSys for new orders AND Orthanc for new
# studies (ms). 30s gives near-real-time without burning CPU.
POLL_INTERVAL_MS=30000

# Log level: debug | info | warn | error
LOG_LEVEL=info
